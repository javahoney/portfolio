---
interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { title, description, image } = Astro.props;
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		{description && <meta property="og:description" content={description} />}
		{image && <meta property="og:image" content={image} />}

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Montserrat:wght@500;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	html {
		box-sizing: border-box;
	}
	*,
	*::before,
	*::after {
		box-sizing: inherit;
	}
	body {
		margin: 0;
		background: #fafafa;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		letter-spacing: -0.03em;
		color: #333333;
	}

	.eyebrow {
		margin: 0;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: #00259e;
	}

	.diamond {
		width: 8px;
		height: 8px;
		background: #00259e;
		transform: rotate(45deg);
		flex-shrink: 0;
	}

	.diamond--white {
		background: #fff;
	}

	.btn {
		display: inline-block;
		text-decoration: none;
		border-radius: 0;
		font-family: "Montserrat", sans-serif;
		font-weight: 600;
		font-size: 0.875rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 12px 24px;
		transition: background-color 0.2s ease-out, color 0.2s ease-out;
	}

	.btn--primary {
		background: #ecf7e4;
		color: #00259e;
		border: 1px solid transparent;
	}

	.btn--primary:hover {
		background: #00259e;
		color: #fff;
	}

	.btn--secondary {
		background: #ffffff;
		color: #00259e;
		border: 1px solid #00259e;
	}

	.btn--secondary:hover {
		background: #00259e;
		color: #fff;
		border-color: #00259e;
	}

	.navlink {
		display: inline-block;
		background: #ecf7e4;
		color: #00259e;
		font-family: "Montserrat", sans-serif;
		font-weight: 600;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		text-decoration: none;
		padding: 8px 16px;
		border-radius: 0;
		transition: background-color 0.2s ease-out, color 0.2s ease-out;
	}

	.navlink:hover {
		background: #00259e;
		color: #fff;
	}

	.text-link {
		color: #00259e;
		text-decoration: underline;
		text-underline-offset: 4px;
		transition: text-decoration-thickness 0.2s ease-out;
	}

	.text-link:hover {
		text-decoration-thickness: 2px;
	}

	.section {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 48px 120px;
	}

	.section-title {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-bottom: 64px;
	}

	.section-title__line {
		flex: 1;
		height: 2px;
		background: #00259e;
	}

	.section-title__text {
		margin: 0;
		font-family: "Cormorant Garamond", serif;
		font-weight: 600;
		letter-spacing: -0.04em;
		font-size: clamp(2.25rem, 4vw, 3rem);
		line-height: 1.06;
		color: #00259e;
		white-space: nowrap;
	}

	@media (max-width: 640px) {
		.section {
			padding: 0 12px 64px;
		}

		.section-title {
			margin-bottom: 40px;
		}

		.section-title__text {
			font-size: 2rem;
		}
	}
</style>
