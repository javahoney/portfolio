---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import SectionTitle from "../components/SectionTitle.astro";

const email = "alexandrelobo550@gmail.com";
const subject = "Démarrer un projet";
const body = `Bonjour Alexandre,

Je souhaite échanger sur un projet de site web.

Type de projet :
Délai souhaité :
Budget approximatif :

Quelques précisions sur mon activité et mon besoin :


Merci !`;
const mailtoHref = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

const projectEntries = await getCollection("projects");
const projects = projectEntries
	.map((entry) => ({ id: entry.id, ...entry.data }))
	.sort((a, b) => a.order - b.order);
---

<Layout title="Alexandre">
	<Nav />

	<main>
		<section class="hero">
			<p class="eyebrow">Alexandre Lobo</p>
			<h1 class="hero__title">Un site performant,<br />que vous pilotez seul</h1>
			<a class="btn btn--primary btn--cta" href={mailtoHref} target="_blank" rel="noopener noreferrer">Démarrer un projet</a>
		</section>

		<section class="section" id="projets">
			<SectionTitle text="Réalisations / 2026" />

			<div class="projects">
				{projects.map((project) => (
					<a class="project" href={`/projets/${project.id}`}>
						<div class="project__media">
							<div class="project__media-inner"></div>
						</div>
						<h3 class="project__name">{project.name}</h3>
						<p class="project__meta">{project.category}</p>
					</a>
				))}
			</div>
		</section>

		<section class="section" id="approche">
			<SectionTitle text="Mon approche" />

			<div class="approach">
				<div class="approach__row">
					<p class="approach__text">Je pars de vos objectifs business,<br />et je construis autour.</p>
					<span class="approach__icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00259E" stroke-width="1.5">
							<rect x="3" y="7" width="18" height="12"></rect>
							<path d="M8 7V5C8 4 8.5 3 10 3H14C15.5 3 16 4 16 5V7"></path>
							<line x1="3" y1="12" x2="21" y2="12"></line>
						</svg>
					</span>
				</div>
				<div class="approach__row">
					<p class="approach__text">Conception de sites vitrines,<br />du design à la mise en ligne.</p>
					<span class="approach__icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00259E" stroke-width="1.5">
							<circle cx="12" cy="12" r="9"></circle>
							<ellipse cx="12" cy="12" rx="4" ry="9"></ellipse>
							<line x1="3" y1="12" x2="21" y2="12"></line>
						</svg>
					</span>
				</div>
				<div class="approach__row">
					<p class="approach__text">Autonomie totale à la livraison,<br />je vous forme à piloter votre site seul.</p>
					<span class="approach__icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00259E" stroke-width="1.5">
							<path d="M21 3L3 10.5L11 13L21 3Z"></path>
							<path d="M11 13L14 21L21 3" stroke-linejoin="round"></path>
						</svg>
					</span>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	.hero {
		max-width: 1400px;
		margin: 0 auto;
		padding: 96px 48px 160px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 24px;
	}

	.hero__title {
		margin: 0;
		font-family: "Cormorant Garamond", serif;
		font-weight: 600;
		letter-spacing: -0.04em;
		line-height: 1.02;
		color: #00259e;
		font-size: clamp(3.5rem, 8vw, 4.5rem);
	}

	.btn--cta {
		margin-top: 16px;
	}

	.projects {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 16px;
	}

	.project {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.project__media {
		aspect-ratio: 4 / 3;
		overflow: hidden;
	}

	.project__media-inner {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, #dde5f0, #c2cee0);
		transition: transform 0.4s ease-out;
	}

	.project:hover .project__media-inner {
		transform: scale(1.03);
	}

	.project__name {
		margin: 16px 0 8px;
		font-family: "Cormorant Garamond", serif;
		font-weight: 600;
		letter-spacing: -0.04em;
		line-height: 1.15;
		font-size: 1.5rem;
		color: #00259e;
	}

	.project__meta {
		margin: 0;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		font-size: 0.875rem;
		line-height: 1.5;
		letter-spacing: -0.03em;
		color: #333333;
	}

	.approach {
		display: flex;
		flex-direction: column;
	}

	.approach__row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 32px 0;
	}

	.approach__row + .approach__row {
		border-top: 1px solid #e5e5e5;
	}

	.approach__text {
		margin: 0;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		font-size: 1rem;
		line-height: 1.6;
		letter-spacing: -0.03em;
		color: #333333;
		max-width: 640px;
	}

	.approach__icon {
		flex-shrink: 0;
		display: flex;
	}

	@media (max-width: 640px) {
		.hero {
			padding: 64px 12px 96px;
			gap: 16px;
		}

		.hero__title {
			font-size: 3rem;
		}

		.projects {
			grid-template-columns: 1fr;
		}

		.approach__row {
			gap: 16px;
			padding: 24px 0;
		}
	}
</style>
