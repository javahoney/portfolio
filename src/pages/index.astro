---
import { getCollection } from "astro:content";

const email = "alexandrelobo550@gmail.com";
const subject = "Démarrer un projet";
const body = `Bonjour Alexandre,

Je souhaite échanger sur un projet de site web.

Type de projet :
Délai souhaité :
Budget approximatif :

Quelques précisions sur mon activité et mon besoin :


Merci !`;
const mailtoHref = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

const whatsappMessage = "Bonjour Alexandre, je vous contacte via votre portfolio au sujet d'un projet de site web. Auriez-vous un moment pour en discuter ?";
const whatsappHref = `https://wa.me/33773532515?text=${encodeURIComponent(whatsappMessage)}`;

const projectEntries = await getCollection("projects");
const projects = projectEntries
	.map((entry) => entry.data)
	.sort((a, b) => a.order - b.order);
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Alexandre</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Montserrat:wght@500;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<header class="nav">
			<div class="nav__inner">
				<nav class="nav__links">
					<a class="navlink" href="#projets">Projets</a>
					<a class="navlink" href="#approche">Approche</a>
					<a class="navlink" href="#contact">Me contacter</a>
				</nav>
			</div>
		</header>

		<main>
			<section class="hero">
				<p class="eyebrow">Alexandre Lobo</p>
				<h1 class="hero__title">Un site performant,<br />que vous pilotez seul</h1>
				<a class="btn btn--primary btn--cta" href={mailtoHref} target="_blank" rel="noopener noreferrer">Démarrer un projet</a>
			</section>

			<section class="section" id="projets">
				<div class="section-title">
					<span class="section-title__line" aria-hidden="true"></span>
					<span class="diamond" aria-hidden="true"></span>
					<h2 class="section-title__text">Réalisations / 2026</h2>
				</div>

				<div class="projects">
					{projects.map((project) => (
						<article class="project">
							<div class="project__media">
								<div class="project__media-inner"></div>
							</div>
							<h3 class="project__name">{project.name}</h3>
							<p class="project__meta">{project.category}</p>
						</article>
					))}
				</div>
			</section>

			<section class="section" id="approche">
				<div class="section-title">
					<span class="section-title__line" aria-hidden="true"></span>
					<span class="diamond" aria-hidden="true"></span>
					<h2 class="section-title__text">Mon approche</h2>
				</div>

				<div class="approach">
					<div class="approach__row">
						<p class="approach__text">Je pars de vos objectifs business,<br />et je construis autour.</p>
						<span class="approach__icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00259E" stroke-width="1.5">
								<rect x="3" y="7" width="18" height="12"></rect>
								<path d="M8 7V5C8 4 8.5 3 10 3H14C15.5 3 16 4 16 5V7"></path>
								<line x1="3" y1="12" x2="21" y2="12"></line>
							</svg>
						</span>
					</div>
					<div class="approach__row">
						<p class="approach__text">Conception de sites vitrines,<br />du design à la mise en ligne.</p>
						<span class="approach__icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00259E" stroke-width="1.5">
								<circle cx="12" cy="12" r="9"></circle>
								<ellipse cx="12" cy="12" rx="4" ry="9"></ellipse>
								<line x1="3" y1="12" x2="21" y2="12"></line>
							</svg>
						</span>
					</div>
					<div class="approach__row">
						<p class="approach__text">Autonomie totale à la livraison,<br />je vous forme à piloter votre site seul.</p>
						<span class="approach__icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00259E" stroke-width="1.5">
								<path d="M21 3L3 10.5L11 13L21 3Z"></path>
								<path d="M11 13L14 21L21 3" stroke-linejoin="round"></path>
							</svg>
						</span>
					</div>
				</div>
			</section>
		</main>

		<footer class="footer" id="contact">
			<div class="footer__inner">
				<p class="footer__heading">Un site performant et raffiné,<br />que vous pilotez seul de A à Z.</p>
				<a class="footer__email" href={mailtoHref} target="_blank" rel="noopener noreferrer">{email}</a>
				<div class="footer__socials">
					<a
						class="footer__social"
						href="https://www.linkedin.com/in/alexandre-lobo-274890326"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="LinkedIn"
					>
						<svg width="18" height="18" viewBox="0 0 448 512" fill="currentColor">
							<path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"></path>
						</svg>
					</a>
					<a
						class="footer__social"
						href={whatsappHref}
						target="_blank"
						rel="noopener noreferrer"
						aria-label="WhatsApp"
					>
						<svg width="18" height="18" viewBox="0 0 448 512" fill="currentColor">
							<path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.9 34.9 55.1 81.2 55 130.5 0 101.8-84.9 184.6-186.5 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"></path>
						</svg>
					</a>
				</div>
				<div class="footer__divider">
					<span class="diamond diamond--white" aria-hidden="true"></span>
				</div>
				<p class="footer__copyright">© 2026 Alexandre Lobo.</p>
			</div>
		</footer>

		<style>
			:global(html) {
				box-sizing: border-box;
			}
			:global(*, *::before, *::after) {
				box-sizing: inherit;
			}
			:global(body) {
				margin: 0;
				background: #fafafa;
				font-family: "Montserrat", sans-serif;
				font-weight: 500;
				letter-spacing: -0.03em;
				color: #333333;
			}

			.nav__inner {
				max-width: 1400px;
				margin: 0 auto;
				padding: 24px 48px;
				display: flex;
				align-items: center;
				justify-content: flex-end;
			}

			.nav__links {
				display: flex;
				gap: 8px;
			}

			.navlink {
				display: inline-block;
				background: #ecf7e4;
				color: #00259e;
				font-family: "Montserrat", sans-serif;
				font-weight: 600;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				text-decoration: none;
				padding: 8px 16px;
				border-radius: 0;
				transition: background-color 0.2s ease-out, color 0.2s ease-out;
			}

			.navlink:hover {
				background: #00259e;
				color: #fff;
			}

			.hero {
				max-width: 1400px;
				margin: 0 auto;
				padding: 96px 48px 160px;
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				gap: 24px;
			}

			.eyebrow {
				margin: 0;
				font-family: "Montserrat", sans-serif;
				font-weight: 500;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: #00259e;
			}

			.hero__title {
				margin: 0;
				font-family: "Cormorant Garamond", serif;
				font-weight: 600;
				letter-spacing: -0.04em;
				line-height: 1.02;
				color: #00259e;
				font-size: clamp(3.5rem, 8vw, 4.5rem);
			}

			.btn {
				display: inline-block;
				text-decoration: none;
				border-radius: 0;
				font-family: "Montserrat", sans-serif;
				font-weight: 600;
				font-size: 0.875rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				padding: 12px 24px;
				transition: background-color 0.2s ease-out, color 0.2s ease-out;
			}

			.btn--primary {
				background: #ecf7e4;
				color: #00259e;
			}

			.btn--primary:hover {
				background: #00259e;
				color: #fff;
			}

			.btn--cta {
				margin-top: 16px;
			}

			.section {
				max-width: 1400px;
				margin: 0 auto;
				padding: 0 48px 120px;
			}

			.section-title {
				display: flex;
				align-items: center;
				gap: 16px;
				margin-bottom: 64px;
			}

			.section-title__line {
				flex: 1;
				height: 2px;
				background: #00259e;
			}

			.section-title__text {
				margin: 0;
				font-family: "Cormorant Garamond", serif;
				font-weight: 600;
				letter-spacing: -0.04em;
				font-size: clamp(2.25rem, 4vw, 3rem);
				line-height: 1.06;
				color: #00259e;
				white-space: nowrap;
			}

			.diamond {
				width: 8px;
				height: 8px;
				background: #00259e;
				transform: rotate(45deg);
				flex-shrink: 0;
			}

			.diamond--white {
				background: #fff;
			}

			.projects {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 16px;
			}

			.project__media {
				aspect-ratio: 4 / 3;
				overflow: hidden;
			}

			.project__media-inner {
				width: 100%;
				height: 100%;
				background: linear-gradient(135deg, #dde5f0, #c2cee0);
				transition: transform 0.4s ease-out;
			}

			.project:hover .project__media-inner {
				transform: scale(1.03);
			}

			.project__name {
				margin: 16px 0 8px;
				font-family: "Cormorant Garamond", serif;
				font-weight: 600;
				letter-spacing: -0.04em;
				line-height: 1.15;
				font-size: 1.5rem;
				color: #00259e;
			}

			.project__meta {
				margin: 0;
				font-family: "Montserrat", sans-serif;
				font-weight: 500;
				font-size: 0.875rem;
				line-height: 1.5;
				letter-spacing: -0.03em;
				color: #333333;
			}

			.approach {
				display: flex;
				flex-direction: column;
			}

			.approach__row {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 24px;
				padding: 32px 0;
			}

			.approach__row + .approach__row {
				border-top: 1px solid #e5e5e5;
			}

			.approach__text {
				margin: 0;
				font-family: "Montserrat", sans-serif;
				font-weight: 500;
				font-size: 1rem;
				line-height: 1.6;
				letter-spacing: -0.03em;
				color: #333333;
				max-width: 640px;
			}

			.approach__icon {
				flex-shrink: 0;
				display: flex;
			}

			.footer {
				background: #00259e;
				color: #fff;
			}

			.footer__inner {
				max-width: 1400px;
				margin: 0 auto;
				padding: 120px 48px;
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				gap: 24px;
			}

			.footer__heading {
				margin: 0;
				font-family: "Cormorant Garamond", serif;
				font-weight: 600;
				letter-spacing: -0.04em;
				line-height: 1.15;
				color: #fff;
				font-size: 1.5rem;
			}

			.footer__email {
				color: #fff;
				text-decoration: underline;
				text-underline-offset: 4px;
				font-family: "Montserrat", sans-serif;
				font-weight: 500;
				font-size: 1rem;
				letter-spacing: -0.03em;
				transition: text-decoration-thickness 0.2s ease-out;
			}

			.footer__email:hover {
				text-decoration-thickness: 2px;
			}

			.footer__socials {
				display: flex;
				gap: 16px;
			}

			.footer__social {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 40px;
				height: 40px;
				background: #ecf7e4;
				color: #00259e;
				border-radius: 0;
				transition: background-color 0.2s ease-out, color 0.2s ease-out;
			}

			.footer__social:hover {
				background: #00259e;
				color: #fff;
			}

			.footer__divider {
				margin-top: 16px;
			}

			.footer__copyright {
				margin: 0;
				font-family: "Montserrat", sans-serif;
				font-weight: 500;
				font-size: 0.875rem;
				line-height: 1.5;
				letter-spacing: -0.03em;
				color: #b1bce0;
			}

			@media (max-width: 640px) {
				.nav__inner {
					padding: 16px 24px;
				}

				.nav__links {
					gap: 8px;
					flex-wrap: wrap;
					justify-content: flex-end;
				}

				.hero {
					padding: 64px 24px 96px;
					gap: 16px;
				}

				.section {
					padding: 0 24px 64px;
				}

				.section-title {
					margin-bottom: 40px;
				}

				.projects {
					grid-template-columns: 1fr;
				}

				.approach__row {
					gap: 16px;
					padding: 24px 0;
				}

				.footer__inner {
					padding: 64px 24px;
					gap: 16px;
				}
			}
		</style>
	</body>
</html>
