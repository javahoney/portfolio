---
import Layout from "../layouts/Layout.astro";
import CompactLabel from "../components/CompactLabel.astro";

const email = "contact@alexandre-lobo.com";
const subject = "Besoin de renfort - création de site web";
const body = `Bonjour Alexandre,

Je vous contacte au sujet de votre offre agence en marque blanche.

Type de projet à externaliser :
Volume estimé (ponctuel / récurrent) :
Délai souhaité :

Merci !`;
const mailtoHref = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

const description =
	"Production Webflow & Framer en marque blanche pour agences : intégration, SEO technique de base et délais tenus, une seule personne à briefer.";

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	serviceType: "Web Development",
	description,
	provider: {
		"@type": "Person",
		name: "Alexandre Lobo",
		url: "https://alexandre-lobo.com",
	},
	areaServed: "France",
	hasOfferCatalog: {
		"@type": "OfferCatalog",
		name: "Formules de production Webflow / Framer",
		itemListElement: [
			{
				"@type": "Offer",
				itemOffered: { "@type": "Service", name: "Landing page" },
				priceSpecification: {
					"@type": "PriceSpecification",
					minPrice: 500,
					maxPrice: 1000,
					priceCurrency: "EUR",
				},
			},
			{
				"@type": "Offer",
				itemOffered: { "@type": "Service", name: "Site 3–5 pages" },
				priceSpecification: {
					"@type": "PriceSpecification",
					minPrice: 1000,
					maxPrice: 2000,
					priceCurrency: "EUR",
				},
			},
			{
				"@type": "Offer",
				itemOffered: { "@type": "Service", name: "Site + CMS" },
				priceSpecification: {
					"@type": "PriceSpecification",
					minPrice: 1500,
					maxPrice: 3000,
					priceCurrency: "EUR",
				},
			},
		],
	},
};
---

<Layout
	title="Offre agence — Production Webflow / Framer en marque blanche | Alexandre Lobo"
	description={description}
	structuredData={serviceSchema}
>
	<header class="mb-header">
		<div class="mb-header__inner">
			<p class="eyebrow mb-header__eyebrow">
				Alexandre Lobo <span class="diamond diamond--white" aria-hidden="true"></span> Offre agence — Marque blanche
			</p>
			<h1 class="mb-header__title">Production Webflow &amp; Framer,<br />livrée en votre nom.</h1>
			<p class="mb-header__subtitle">
				Votre agence garde le contrôle. Je m'occupe de l'intégration technique, du responsive au SEO de base en white
				label pour vos projets de site vitrine.
			</p>
		</div>
	</header>

	<main>
		<section class="mb-section mb-section--first">
			<CompactLabel text="Scope inclus" />

			<div class="scope-grid">
				<div class="scope-col">
					<ul class="scope-list scope-list--included">
						<li>
							<span class="scope-bullet scope-bullet--check" aria-hidden="true">
								<svg width="10" height="10" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 9l3 3 7-7"></path>
								</svg>
							</span>
							Intégration Webflow ou Framer
						</li>
						<li>
							<span class="scope-bullet scope-bullet--check" aria-hidden="true">
								<svg width="10" height="10" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 9l3 3 7-7"></path>
								</svg>
							</span>
							Responsive desktop / tablette / mobile
						</li>
						<li>
							<span class="scope-bullet scope-bullet--check" aria-hidden="true">
								<svg width="10" height="10" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 9l3 3 7-7"></path>
								</svg>
							</span>
							Animations simples (hover, scroll, transitions)
						</li>
						<li>
							<span class="scope-bullet scope-bullet--check" aria-hidden="true">
								<svg width="10" height="10" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 9l3 3 7-7"></path>
								</svg>
							</span>
							CMS (blogs, catalogues)
						</li>
						<li>
							<span class="scope-bullet scope-bullet--check" aria-hidden="true">
								<svg width="10" height="10" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 9l3 3 7-7"></path>
								</svg>
							</span>
							SEO technique de base — balises, structure, meta, alt, compression images
						</li>
					</ul>
				</div>

				<div class="scope-col">
					<ul class="scope-list scope-list--excluded">
						<li>
							<span class="scope-bullet scope-bullet--cross" aria-hidden="true">
								<svg width="10" height="10" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
									<path d="M4 4l10 10M14 4L4 14"></path>
								</svg>
							</span>
							Logique métier avancée, moteur de recherche avancé, web app / dashboard
						</li>
						<li>
							<span class="scope-bullet scope-bullet--cross" aria-hidden="true">
								<svg width="10" height="10" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
									<path d="M4 4l10 10M14 4L4 14"></path>
								</svg>
							</span>
							Dev custom lourd — JS avancé, backend, API complexes
						</li>
						<li>
							<span class="scope-bullet scope-bullet--cross" aria-hidden="true">
								<svg width="10" height="10" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
									<path d="M4 4l10 10M14 4L4 14"></path>
								</svg>
							</span>
							Création d'assets — visuels custom, vidéos, illustrations
						</li>
					</ul>
					<p class="scope-note">Utilisation d'assets libres de droit incluse.</p>
				</div>
			</div>
		</section>

		<section class="mb-section">
			<CompactLabel text="Révisions" />

			<div class="revision-bar">
				<div class="revision-bar__text">
					<p class="revision-bar__title">2 cycles de révisions inclus</p>
					<p class="revision-bar__subtext">Retours attendus sous 48h côté agence / client</p>
				</div>
				<p class="revision-bar__price">+100€ / cycle suppl.</p>
			</div>
		</section>

		<section class="mb-section">
			<CompactLabel text="Pricing" />

			<div class="pricing-table-wrap">
				<table class="pricing-table">
					<thead>
						<tr>
							<th>Formule</th>
							<th>Tarif</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td>Landing page</td>
							<td class="pricing-table__price">500 – 1 000 €</td>
						</tr>
						<tr>
							<td>Site 3–5 pages</td>
							<td class="pricing-table__price">1 000 – 2 000 €</td>
						</tr>
						<tr>
							<td>Site + CMS</td>
							<td class="pricing-table__price">1 500 – 3 000 €</td>
						</tr>
					</tbody>
				</table>
			</div>
		</section>

		<section class="mb-section">
			<CompactLabel text="Options" />

			<div class="options-grid">
				<div class="option-card">
					<div class="option-card__header">
						<h3 class="option-card__title">SEO technique, tracking &amp; mise en ligne</h3>
						<span class="option-card__badge">+300 à 600 €</span>
					</div>
					<ul class="option-card__list">
						<li>Mise en ligne et connexion du domaine</li>
						<li>Setup Google Search Console (indexation)</li>
						<li>Setup GA4</li>
						<li>Analyse PageSpeed + corrections simples essentielles</li>
						<li>Mini livrable : points corrigés + recommandations</li>
					</ul>
				</div>

				<div class="option-card">
					<div class="option-card__header">
						<h3 class="option-card__title">Automatisation no-code</h3>
						<span class="option-card__badge">+200 à 1 000 €</span>
					</div>
					<ul class="option-card__list">
						<li>Connexion du site à vos outils (CRM, Airtable, email…)</li>
						<li>Automatisation des leads — réception, stockage, notifications</li>
						<li>Logiques simples de qualification</li>
					</ul>
				</div>

				<div class="option-card">
					<div class="option-card__header">
						<h3 class="option-card__title">Design &amp; contenu</h3>
						<span class="option-card__badge">Landing +250–500€ · Site +500–1000€</span>
					</div>
					<ul class="option-card__list">
						<li>Design from scratch</li>
						<li>Navigation, UX, mapping des URL (SEO)</li>
						<li>Branding</li>
						<li>Copywriting</li>
						<li>Recherche d'assets libres de droit</li>
					</ul>
				</div>
			</div>
		</section>

		<section class="mb-section">
			<CompactLabel text="Délais" />

			<div class="delays-grid">
				<div class="delay-block">
					<p class="delay-block__label eyebrow">Landing</p>
					<p class="delay-block__value">4–7 jours</p>
				</div>
				<div class="delay-block">
					<p class="delay-block__label eyebrow">Site</p>
					<p class="delay-block__value">7–14 jours</p>
				</div>
				<div class="delay-block">
					<p class="delay-block__label eyebrow">CMS</p>
					<p class="delay-block__value">7–21 jours</p>
				</div>
			</div>
			<p class="delays-note">Condition : retours de révision transmis sous 48h côté agence / client.</p>
		</section>
	</main>

	<footer class="mb-footer">
		<div class="mb-footer__inner">
			<p class="mb-footer__heading">Un projet client à externaliser ?</p>
			<p class="mb-footer__text">
				Marque blanche, délais tenus, une seule personne à briefer du wireframe au SEO technique.
			</p>
			<a class="btn btn--primary mb-footer__cta" href={mailtoHref} target="_blank" rel="noopener noreferrer">
				Échanger sur votre prochain projet
			</a>
			<p class="mb-footer__contact">{email}</p>
			<div class="mb-footer__socials">
				<a
					class="mb-footer__social"
					href="https://www.linkedin.com/in/alexandre-lobo-274890326"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="LinkedIn"
				>
					<svg width="18" height="18" viewBox="0 0 448 512" fill="currentColor">
						<path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"></path>
					</svg>
				</a>
				<a class="mb-footer__social" href="/" target="_blank" rel="noopener noreferrer" aria-label="Retour au portfolio">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
						<rect x="3" y="7" width="18" height="12"></rect>
						<path d="M8 7V5C8 4 8.5 3 10 3H14C15.5 3 16 4 16 5V7"></path>
						<line x1="3" y1="12" x2="21" y2="12"></line>
					</svg>
				</a>
			</div>
		</div>
	</footer>
</Layout>

<style>
	.mb-header {
		background: #00259e;
	}

	.mb-header__inner {
		max-width: 1400px;
		margin: 0 auto;
		padding: 96px 48px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 24px;
	}

	.mb-header__eyebrow.eyebrow {
		display: flex;
		align-items: center;
		gap: 8px;
		color: #ecf7e4;
	}

	.mb-header__title {
		margin: 0;
		font-family: "Cormorant Garamond", serif;
		font-weight: 600;
		letter-spacing: -0.04em;
		line-height: 1.04;
		color: #fff;
		font-size: clamp(3.5rem, 8vw, 4.5rem);
	}

	.mb-header__subtitle {
		margin: 0;
		max-width: 640px;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		font-size: 1rem;
		line-height: 1.6;
		letter-spacing: -0.03em;
		color: #fff;
	}

	.mb-section {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 48px 120px;
	}

	.mb-section--first {
		padding-top: 96px;
	}

	.scope-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 40px;
	}

	.scope-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.scope-list li {
		display: flex;
		align-items: flex-start;
		gap: 8px;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		font-size: 1rem;
		line-height: 1.6;
		letter-spacing: -0.03em;
	}

	.scope-list--included li {
		color: #333333;
	}

	.scope-list--excluded li {
		color: #5a6488;
	}

	.scope-bullet {
		width: 18px;
		height: 18px;
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-top: 4px;
	}

	.scope-bullet--check {
		background: #ecf7e4;
		color: #00259e;
	}

	.scope-bullet--cross {
		background: transparent;
		border: 1px solid #00259e;
		color: #00259e;
	}

	.scope-note {
		margin: 16px 0 0;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		font-style: italic;
		font-size: 0.875rem;
		line-height: 1.5;
		color: #5a6488;
	}

	.revision-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		background: #fff;
		border: 1px solid #e5e5e5;
		padding: 32px;
	}

	.revision-bar__title {
		margin: 0;
		font-family: "Montserrat", sans-serif;
		font-weight: 600;
		font-size: 1rem;
		line-height: 1.6;
		letter-spacing: -0.03em;
		color: #333333;
	}

	.revision-bar__subtext {
		margin: 8px 0 0;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		font-size: 0.875rem;
		line-height: 1.5;
		letter-spacing: -0.03em;
		color: #5a6488;
	}

	.revision-bar__price {
		margin: 0;
		flex-shrink: 0;
		font-family: "Cormorant Garamond", serif;
		font-weight: 600;
		letter-spacing: -0.04em;
		line-height: 1.15;
		font-size: 1.5rem;
		color: #00259e;
	}

	.pricing-table-wrap {
		overflow-x: auto;
	}

	.pricing-table {
		width: 100%;
		border-collapse: collapse;
	}

	.pricing-table th {
		background: #00259e;
		color: #fff;
		text-align: left;
		font-family: "Montserrat", sans-serif;
		font-weight: 600;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		padding: 16px 24px;
	}

	.pricing-table th:last-child {
		text-align: right;
	}

	.pricing-table td {
		border: 1px solid #e5e5e5;
		padding: 16px 24px;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		font-size: 1rem;
		line-height: 1.6;
		letter-spacing: -0.03em;
		color: #333333;
	}

	.pricing-table__price {
		text-align: right;
		font-family: "Cormorant Garamond", serif;
		font-weight: 600;
		letter-spacing: -0.04em;
		line-height: 1.15;
		font-size: 1.5rem;
		color: #00259e;
	}

	.options-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	.option-card {
		background: #fff;
		border: 1px solid #e5e5e5;
		padding: 32px;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.option-card__header {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.option-card__title {
		margin: 0;
		font-family: "Cormorant Garamond", serif;
		font-weight: 600;
		letter-spacing: -0.04em;
		line-height: 1.15;
		font-size: 1.5rem;
		color: #00259e;
	}

	.option-card__badge {
		align-self: flex-start;
		background: #ecf7e4;
		color: #00259e;
		font-family: "Montserrat", sans-serif;
		font-weight: 600;
		font-size: 0.875rem;
		line-height: 1.5;
		letter-spacing: -0.03em;
		padding: 8px 16px;
	}

	.option-card__list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.option-card__list li {
		position: relative;
		padding-left: 16px;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		font-size: 0.875rem;
		line-height: 1.5;
		letter-spacing: -0.03em;
		color: #333333;
	}

	.option-card__list li::before {
		content: "";
		position: absolute;
		left: 0;
		top: 8px;
		width: 4px;
		height: 4px;
		background: #00259e;
	}

	.delays-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
	}

	.delay-block {
		border: 1px solid #e5e5e5;
		padding: 32px;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.delay-block__value {
		margin: 0;
		font-family: "Cormorant Garamond", serif;
		font-weight: 600;
		letter-spacing: -0.04em;
		line-height: 1.15;
		font-size: 1.5rem;
		color: #00259e;
	}

	.delays-note {
		margin: 24px 0 0;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		font-style: italic;
		font-size: 0.875rem;
		line-height: 1.5;
		color: #5a6488;
	}

	.mb-footer {
		background: #00259e;
	}

	.mb-footer__inner {
		max-width: 1400px;
		margin: 0 auto;
		padding: 120px 48px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 24px;
	}

	.mb-footer__heading {
		margin: 0;
		font-family: "Cormorant Garamond", serif;
		font-weight: 600;
		letter-spacing: -0.04em;
		line-height: 1.15;
		color: #fff;
		font-size: 1.5rem;
	}

	.mb-footer__text {
		margin: 0;
		max-width: 560px;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		font-size: 1rem;
		line-height: 1.6;
		letter-spacing: -0.03em;
		color: #fff;
	}

	.mb-footer__contact {
		margin: 0;
		font-family: "Montserrat", sans-serif;
		font-weight: 500;
		font-size: 1rem;
		line-height: 1.6;
		letter-spacing: -0.03em;
		color: #fff;
	}

	.mb-footer__socials {
		display: flex;
		gap: 16px;
	}

	.mb-footer__social {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		background: #ecf7e4;
		color: #00259e;
		transition: background-color 0.2s ease-out, color 0.2s ease-out;
	}

	.mb-footer__social:hover {
		background: #00259e;
		color: #fff;
	}

	@media (max-width: 640px) {
		.mb-header__inner {
			padding: 64px 12px;
		}

		.mb-header__title {
			font-size: 3rem;
		}

		.mb-section {
			padding: 0 12px 64px;
		}

		.mb-section--first {
			padding-top: 64px;
		}

		.scope-grid {
			grid-template-columns: 1fr;
			gap: 32px;
		}

		.revision-bar {
			flex-direction: column;
			align-items: flex-start;
			padding: 24px;
		}

		.options-grid {
			grid-template-columns: 1fr;
		}

		.option-card {
			padding: 24px;
		}

		.delays-grid {
			grid-template-columns: 1fr;
		}

		.delay-block {
			padding: 24px;
		}

		.mb-footer__inner {
			padding: 64px 12px;
			gap: 16px;
		}
	}
</style>
